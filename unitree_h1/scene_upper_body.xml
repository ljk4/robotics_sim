<mujoco model="h1_upper_body_scene">
  <!-- ============================================================
       Unitree H1 人形机器人 - 上身场景文件
       通过 <include> 引用 h1_upper_body.xml 模型定义
       在此基础上添加仿真环境：天空、地面、光照、关键帧
       骨盆已固定，可直接用于上身运动的独立仿真
       ============================================================ -->

  <!-- ===== 引用上身模型文件 =====
       h1_upper_body.xml 包含：
       - 编译器设置、默认属性
       - 上身所需的所有网格资源
       - 骨盆(固定) + 躯干 + 双臂 运动学树
       - 上身9个驱动电机的执行器定义 -->
  <include file="h1_upper_body.xml"/>

  <!-- ===== 场景统计 =====
       center  - 场景观察中心点(上身重心附近)
       extent  - 场景包围盒半边长，控制默认摄像机距离 -->
  <statistic center="0 0 1.3" extent="1.2"/>

  <!-- ===== 可视化设置 ===== -->
  <visual>
    <!-- 头灯：跟随摄像机的默认光源
         diffuse  - 漫反射光颜色(0.6灰)
         ambient  - 环境光颜色(0.3灰)
         specular - 镜面高光(全0=无高光) -->
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <!-- 大气雾效：rgba定义雾的颜色和浓度
         haze前三通道为颜色(淡蓝灰)，第四通道为强度 -->
    <rgba haze="0.15 0.25 0.35 1"/>
    <!-- 全局摄像机默认视角
         azimuth  - 水平方位角160°（偏向侧面观察）
         elevation - 俯仰角-20°（略微俯视上身） -->
    <global azimuth="160" elevation="-20"/>
  </visual>

  <!-- ===== 场景资源 =====
       加载场景环境所需的纹理和材质
       上身模型本身的网格资源已在 h1_upper_body.xml 中定义 -->
  <asset>
    <!-- 天空盒：垂直渐变纹理模拟天空
         rgb1="0.3 0.5 0.7" 顶部浅蓝色
         rgb2="0 0 0"         底部黑色 -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>

    <!-- 地面纹理：棋盘格图案
         builtin="checker" - 内置棋盘格生成器
         mark="edge"        - 在格子边缘绘制标记线便于识别位置
         rgb1/rgb2          - 深浅交替的格子颜色
         markrgb            - 边缘线颜色(浅灰)
         width/height       - 纹理分辨率 -->
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>

    <!-- 地面材质
         texuniform="true"  - 纹理在世界坐标中均匀平铺
         texrepeat="5 5"    - 5×5棋盘格
         reflectance="0.2"  - 微弱反射率 -->
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <!-- ===== 世界定义 =====
       worldbody元素会与 h1_upper_body.xml 中的worldbody合并
       这里添加场景环境物体：地面和光源 -->
  <worldbody>
    <!-- 垂直方向光源：模拟太阳/天花板灯光
         pos="0 0 3.5"  光照位于上方3.5m
         dir="0 0 -1"    光线垂直向下照射
         directional     平行光（无衰减） -->
    <light pos="0 0 3.5" dir="0 0 -1" directional="true"/>

    <!-- 地面：无限大平面，使用棋盘格材质
         size="0 0 0.05" 前两维0=无限大，第三维=碰撞厚度 -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  </worldbody>

  <!-- ===== 关键帧（预设姿态）=====
       qpos值按关节定义顺序排列，对应上身9个驱动关节：
       torso → left_shoulder_pitch → left_shoulder_roll → left_shoulder_yaw → left_elbow
       → right_shoulder_pitch → right_shoulder_roll → right_shoulder_yaw → right_elbow

       home姿态说明：
       - 躯干关节=0，身体直立不旋转
       - 双臂8个关节均为0，手臂自然下垂
       - 骨盆固定在世界坐标系中，因此无根坐标/姿态值 -->
  <keyframe>
    <key name="home"
      qpos="
    0
    0 0 0 0
    0 0 0 0"/>
  </keyframe>
</mujoco>
